# Copy to .env.local and fill in values. Never commit .env.local.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
GHL_API_KEY=
GHL_LOCATION_ID=
CALLRAIL_ACCOUNT_ID=
CALLRAIL_API_KEY=
RESEND_API_KEY=
NEXT_PUBLIC_APP_URL=
# Comma-separated admin emails; ADMIN_EMAIL below kept as fallback
ADMIN_EMAILS=
ADMIN_EMAIL=

# --- Phase 2: Lead Pipeline ---
# GoHighLevel
GHL_PRIVATE_TOKEN=              # Fallback only (FIX-01): each client's own token is now stored
                                 # encrypted on clients.ghl_private_token_encrypted and captured at
                                 # onboarding. This env var is used only when a client has none set.
GHL_SMS_WORKFLOW_ID=            # ID of pre-configured GHL SMS workflow for lead follow-up
GHL_TOKEN_ENC_KEY=              # 32-byte hex (64 chars) key for AES-256-GCM encryption of per-client GHL tokens (FIX-01)

# Resend
RESEND_FROM_EMAIL=leads@tradeflow.io  # From address for lead notification emails
GET_STARTED_FROM_EMAIL=no-reply@tradeflow-technologies.com  # From address for /get-started inquiry emails (verified domain)

# App URL (used in email links) — set above as NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Phase 4: Operations ---
# GoHighLevel Agency API
GHL_AGENCY_API_KEY=              # Agency-level Private Integration Token for sub-account creation (NOT sub-account token)

# --- Phase 9: Observability (OBSV-01) ---
# Sentry error tracking — optional. Unset = Sentry fully disabled (no-op), no crash.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1

# --- Phase 9: AI lead scoring (AI-01) ---
ANTHROPIC_API_KEY=              # Anthropic API key; when unset, lead urgency scoring is skipped gracefully
