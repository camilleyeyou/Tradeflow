# Copy to .env.local and fill in values. Never commit .env.local.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
GHL_API_KEY=
GHL_LOCATION_ID=
CALLRAIL_ACCOUNT_ID=
CALLRAIL_API_KEY=
RESEND_API_KEY=
NEXT_PUBLIC_APP_URL=
# Comma-separated admin emails; ADMIN_EMAIL below kept as fallback
ADMIN_EMAILS=
ADMIN_EMAIL=

# --- Phase 2: Lead Pipeline ---
# GoHighLevel
GHL_PRIVATE_TOKEN=              # GHL Private Integration Token (per sub-account, NOT NEXT_PUBLIC_)
GHL_SMS_WORKFLOW_ID=            # ID of pre-configured GHL SMS workflow for lead follow-up

# Resend
RESEND_FROM_EMAIL=leads@tradeflow.io  # From address for lead notification emails
GET_STARTED_FROM_EMAIL=no-reply@tradeflow-technologies.com  # From address for /get-started inquiry emails (verified domain)

# App URL (used in email links) — set above as NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Phase 4: Operations ---
# GoHighLevel Agency API
GHL_AGENCY_API_KEY=              # Agency-level Private Integration Token for sub-account creation (NOT sub-account token)
